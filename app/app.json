{
  "expo": {
    "name": "Darzi",
    "slug": "darzi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/darzii.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/darzii.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/darzii.png",
        "backgroundColor": "#F5F5F0"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/darzii.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
